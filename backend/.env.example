# Copy to .env and fill in. If OPENAI_API_KEY is left blank, the backend runs a
# deterministic scripted FNOL agent so the whole stack still works end-to-end.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# Force the scripted (no-LLM) agent even if a key is present:
USE_MOCK_LLM=false

# Telephony (pluggable; not required for local eval). See app/telephony.py.
TELEPHONY_PROVIDER=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
