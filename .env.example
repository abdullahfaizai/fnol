# Copy to .env. Leave OPENAI_API_KEY blank to use the built-in scripted agent
# (the whole stack still runs and files claims end-to-end).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
USE_MOCK_LLM=false

# Telephony (pluggable; not required for local eval). See backend/app/telephony.py.
TELEPHONY_PROVIDER=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=




# Origin the browser uses to reach the backend WebSocket. For local Docker the
# default is correct. Change the host if you deploy elsewhere.
VITE_WS_BASE=ws://localhost:8000
